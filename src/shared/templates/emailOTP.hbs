<div
  style="font-family: sans-serif; padding: 40px 20px; max-width: 600px; margin: 0 auto; background-color: #ffffff; border: 1px solid #eaeaea; border-radius: 8px;"
>

  <div style="text-align: center; margin-bottom: 30px;">
    <img
      src="https://aestheticpixelstudio.com/logoDark.png"
      alt="Aesthetic Pixel Studio Logo"
      style="width: 45px; height: 45px; border-radius: 10px; vertical-align: middle; margin-right: 12px; object-fit: cover;"
    />
    <span
      style="font-size: 26px; font-weight: bold; color: #111827; vertical-align: middle; letter-spacing: -0.5px;"
    >
      Aesthetic Pixel Studio LLC
    </span>
  </div>

  <h3 style="color: #374151; text-align: center;">Verify your Email Address</h3>

  <p style="color: #4B5563; line-height: 1.6;">Hello <b>{{name}}</b>,</p>
  <p style="color: #4B5563; line-height: 1.6;">Please use the verification code
    below to complete your registration. This code will expire in
    <strong>5 minutes</strong>.</p>

  <div
    style="background-color: #f9fafb; border: 1px dashed #d1d5db; padding: 24px; text-align: center; margin: 32px 0; border-radius: 8px;"
  >
    <h1
      style="color: #111827; letter-spacing: 12px; margin: 0; font-size: 36px;"
    >{{otp}}</h1>
  </div>

  <hr style="border: none; border-top: 1px solid #f3f4f6; margin: 32px 0;" />
  <small
    style="color: #9CA3AF; display: block; text-align: center; line-height: 1.5;"
  >
    If you didn't request this code, please safely ignore this email.
  </small>

</div>