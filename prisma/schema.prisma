generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum Angle {
  FRONT
  BACK
  LEFT
  RIGHT
  TOP
  BOTTOM
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum PaymentStatus {
  NOT_PAID
  PARTIALLY_PAID
  COMPLETELY_PAID
}


/* ---------------------------------------------------------------------------*/

model User {
  id              String     @id @default(cuid(2))
  fullName        String
  avatar          String?
  email           String     @unique
  phone           String     @unique
  password        String
  address         String?
  employeeId      String?    @unique
  enable2FA       Boolean?    @default(false)
  
  role            UserRole   @default(USER)
  status          UserStatus @default(ACTIVE)

  isEmailVerified Boolean    @default(false)
  emailVerifiedAt DateTime?

  isPhoneVerified Boolean    @default(false)
  phoneVerifiedAt DateTime?

  refreshTokens   RefreshToken[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  createdById     String?
  updatedById     String?

  createdBy       User?      @relation("UserCreatedBy", fields: [createdById], references: [id])
  updatedBy       User?      @relation("UserUpdatedBy", fields: [updatedById], references: [id])

  createdUsers    User[]     @relation("UserCreatedBy")
  updatedUsers    User[]     @relation("UserUpdatedBy")

  createdClients  Client[] @relation("ClientCreatedBy")
  updatedClients  Client[] @relation("ClientUpdatedBy")

  createdOrders  Order[] @relation("OrderCreatedBy")
  updatedOrders  Order[] @relation("OrderUpdatedBy")
}

/* ---------------------------------------------------------------------------*/

model RefreshToken {
  id        String   @id @default(cuid(2))
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())
}

/* ---------------------------------------------------------------------------*/

model Client {
  id          String   @id @default(cuid(2))
  name        String
  email       String   @unique
  phone       String   @unique
  address     String?

  orders      Order[]

  createdById String
  updatedById String

  createdBy   User    @relation("ClientCreatedBy", fields: [createdById], references: [id])
  updatedBy   User    @relation("ClientUpdatedBy", fields: [updatedById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/* ---------------------------------------------------------------------------*/

model OrderItems {
  id          String   @id @default(cuid(2))
  orderId     String
  
  productName String   
  angle       Angle[]    
  quantity    Int
  rate        Float    
  total       Float  

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id            String        @id @default(cuid(2))
  orderId       String
  clientId      String
  
  status        OrderStatus   @default(PENDING)
  priority      Priority      @default(LOW)
  orderDate     DateTime  
  deadline      DateTime

  paymentStatus PaymentStatus @default(NOT_PAID)
  paidAmount    Float         @default(0)
  dueAmount     Float         @default(0)

  orderItems    OrderItems[]
  totalPrice    Float         @default(0)
  note          String?

  client        Client        @relation(fields: [clientId], references: [id])

  createdById   String
  updatedById   String

  createdBy     User          @relation("OrderCreatedBy", fields: [createdById], references: [id])
  updatedBy     User          @relation("OrderUpdatedBy", fields: [updatedById], references: [id])

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

/* ---------------------------------------------------------------------------*/